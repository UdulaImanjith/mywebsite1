
{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project entry.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["Graphic", "Web", "App Development", "3D"] },
        "subCategory": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "showViewLink": { "type": "boolean", "default": true },
        "projectUrl": { "type": "string" }
      },
      "required": ["title", "category", "description", "imageUrl"]
    },
    "Experience": {
      "title": "Experience",
      "description": "Professional work experience.",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "position": { "type": "string" },
        "duration": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["company", "position", "duration"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client feedback.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "avatar": { "type": "string" }
      },
      "required": ["name", "text"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "#/backend/entities/Project",
      "description": "Collection of portfolio projects."
    },
    "/experiences/{experienceId}": {
      "schema": "#/backend/entities/Experience",
      "description": "Collection of professional experiences."
    },
    "/testimonials/{testimonialId}": {
      "schema": "#/backend/entities/Testimonial",
      "description": "Collection of client testimonials."
    }
  }
}
